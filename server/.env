# ─── 개발/테스트 모드 ───────────────────────────────────────
# true  → DB 없이 누구나 로그인 가능 (테스트 전용)
# false → 실제 DB 조회 + 비밀번호 검증 (운영)
DEV_MOCK_LOGIN=true

# ─── JWT 설정 ───────────────────────────────────────────────
JWT_SECRET=mes_dev_secret_key_change_in_production
JWT_EXPIRES_IN=8h

# ─── 서버 설정 ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MSSQL 데이터베이스 설정 (DEV_MOCK_LOGIN=false 일 때만 사용) ──
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=MES_DB
DB_USER=sa
DB_PASSWORD=your_db_password
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
